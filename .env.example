# Anthropic
ANTHROPIC_API_KEY=

# Neon Postgres
LEAD_PIPELINE_DATABASE_URL=postgresql://user:pass@ep-xxx.pooler.region.neon.tech/leads
LEAD_PIPELINE_DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.region.neon.tech/leads

# Gmail SMTP (app password from myaccount.google.com/apppasswords)
GMAIL_SENDER=${GMAIL_ADDRESS}
GMAIL_APP_PASSWORD=

# Alert recipient for hot lead emails and weekly report
ALERT_RECIPIENT=you@yourcompany.com

# Client-configurable industry context for Claude scoring prompt
INDUSTRY_CONTEXT=business funding lender

# Comma-separated list of rep emails for round-robin assignment
REP_POOL=rep1@company.com,rep2@company.com
